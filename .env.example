# --- Service Authentication (shared secret with Laravel) ---
RAG_SERVICE_TOKEN=secret

# --- Laravel Connection ---
LARAVEL_API_URL=http://localhost:8001

# --- Ollama ---
OLLAMA_URL=http://localhost:11434

# --- Model Configuration ---
TEXT_MODEL=gpt-oss:120b-cloud
VISION_MODEL=minimax-m3:cloud
TEMPERATURE=0.2

# --- Worker ---
WORKER_ENABLED=true
WORKER_POLL_INTERVAL=15
